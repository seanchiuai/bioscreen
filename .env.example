# ── NVIDIA NIM API ────────────────────────────────────────────────────────────
# Obtain at https://build.nvidia.com
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ESMFold NIM endpoint (default points to NVIDIA's hosted inference)
ESMFOLD_API_URL=https://health.api.nvidia.com/v1/biology/nvidia/esmfold

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# ── Model settings ────────────────────────────────────────────────────────────
ESM2_MODEL_NAME=facebook/esm2_t33_650M_UR50D
# Set to "cuda" to use GPU, "cpu" to force CPU inference
DEVICE=cpu

# ── Database paths ────────────────────────────────────────────────────────────
TOXIN_DB_PATH=data/toxin_db.faiss
TOXIN_META_PATH=data/toxin_meta.json

# ── Foldseek ──────────────────────────────────────────────────────────────────
# Path to the foldseek binary (must be installed separately)
FOLDSEEK_BIN=foldseek
FOLDSEEK_DB_PATH=data/foldseek_db

# ── UniProt build settings ────────────────────────────────────────────────────
UNIPROT_BATCH_SIZE=500
MAX_TOXIN_RECORDS=5000

# ── Screening thresholds ──────────────────────────────────────────────────────
EMBEDDING_SIM_THRESHOLD=0.85
STRUCTURE_SIM_THRESHOLD=0.70
RISK_HIGH_THRESHOLD=0.75
RISK_MEDIUM_THRESHOLD=0.50
